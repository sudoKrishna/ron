// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Side {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum PositionType {
  LONG
  SHORT
}

enum PositionStatus {
  OPEN
  CLOSED
}

model User {
  userId String @id @default(cuid())
  username String
  password  String
  createdAt DateTime @default(now())

  collateral Collateral?
  orders Order[]
  posotions Position[]
  fills Fill[]
}

model Asset {
  id String @id @default(cuid())
  symbol String
  name String
  userAssets UserAsset[]
}

model UserAsset {
  id String @id @default(cuid())
  userId String
  assetId String
  balance Decimal @default(0)
  asset Asset @relation(fields: [assetId], references: [id])
  @@unique([userId, assetId])
}


model Collateral {
  id String @id @default(cuid())
  userId String @unique
  available Decimal @default(0)
  locked Decimal @default(0)
  user User @relation(fields: [userId],references: [userId])
}

model Order {
  orderId String @id @default(cuid())
  userId String
  market String
  side Side
  orderType OrderType
  qty Decimal
  price Decimal?
  margin Decimal
  leverage Decimal @default(10)
  status OrderStatus @default(OPEN)

  user User @relation(fields: [userId], references: [userId])
  fills Fill[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  positionId String @id @default(cuid())
  userId String
  market String
  type PositionType
  qty Decimal
  margin Decimal
  entryPrice Decimal
  leverage Decimal
  averagePrice Decimal
  liquidationPrice Decimal
  realizedPnl Decimal  @default(0)
  unrealizedPnl Decimal @default(0)
  status PositionStatus @default(OPEN)
  user User @relation(fields: [userId], references: [userId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fill  {
  id String @id @default(cuid())
  orderId String
  userId String
  market String
  side Side 
  qty Decimal
  price Decimal
  fee Decimal  @default(0)
  buyOrderId String?
  sellOrderId String?

  order Order @relation(fields: [orderId], references: [orderId])
  user User @relation(fields: [userId], references: [userId])

  createdAt DateTime @default(now())
}
model MarketSnapsshot {
  id String @id @default(cuid())
  market String
  markPrice Decimal
  snapshot Json
  createdAt DateTime @default(now())
}


