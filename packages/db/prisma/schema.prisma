// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PositionType {
  LONG
  SHORT
}

enum Side {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
}

enum PositionStatus {
  OPEN
  CLOSED
}

model User {
  userId     Int         @id @default(autoincrement())
  username   String      @unique
  password   String
  collateral Collateral?
  orders     Order[]
  position   Position[]
  fills      Fill[]
  createdAt  DateTime    @default(now())
}

model Collateral {
  id        Int   @id @default(autoincrement())
  available Float
  locked    Float
  userId    Int   @unique
  user      User  @relation(fields: [userId], references: [userId])
}

model Order {
  orderId   Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [userId])
  market    String
  side      Side
  orderType OrderType
  qty       Float
  price     Float
  margin    Float
  leverage  Float
  status    OrderStatus @default(OPEN)
  fills     Fill[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Position {
  positionId Int  @id @default(autoincrement())
  userId     Int
  user       User @relation(fields: [userId], references: [userId])

  market     String
  type       PositionType
  qty        Float
  margin     Float
  entryPrice Float
  leverage   Float

  averagePrice     Float
  liquidationPrice Float
  realizedPnl      Float @default(1)

  unrealizedPnl Float          @default(1)
  status        PositionStatus @default(OPEN)
  createdAt     DateTime       @default(now())
  updateAt      DateTime       @updatedAt
}

model Fill {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [orderId])

  userId      Int
  user        User   @relation(fields: [userId], references: [userId])
  market      String
  buyOrderId  Int?
  sellOrderId Int?
  side Side

  qty       Float
  price     Float
  createdAt DateTime @default(now())
}
